# Application
NODE_ENV=development
LOG_LEVEL=info
GITHUB_TOKEN=your_gh_access_token

# Discord Bot
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_GUILD_ID=optional_guild_id_for_development

# Global Middleware (optional)
MIDDLEWARE_GLOBAL_BOT_FILTER_ENABLED=true
MIDDLEWARE_GLOBAL_RATE_LIMITER_ENABLED=false
MIDDLEWARE_GLOBAL_RATE_LIMITER_WINDOW_MS=60000
MIDDLEWARE_GLOBAL_RATE_LIMITER_MAX_EVENTS=10
MIDDLEWARE_GLOBAL_RATE_LIMITER_BLOCK=true
MIDDLEWARE_GLOBAL_RATE_LIMITER_KEY=userId
MIDDLEWARE_GLOBAL_RATE_LIMITER_PRUNE_INTERVAL_MS=60000
MIDDLEWARE_GLOBAL_PROFANITY_FILTER_ENABLED=false
MIDDLEWARE_GLOBAL_PROFANITY_FILTER_BANNED_WORDS=spam,abuse
MIDDLEWARE_GLOBAL_PROFANITY_FILTER_ACTION=flag
MIDDLEWARE_GLOBAL_PROFANITY_FILTER_REPLACEMENT=***
MIDDLEWARE_GLOBAL_PROFANITY_FILTER_CASE_SENSITIVE=false
MIDDLEWARE_GLOBAL_PROFANITY_FILTER_MATCH_WHOLE_WORD=true
MIDDLEWARE_GLOBAL_LOGGER_ENABLED=false
MIDDLEWARE_GLOBAL_LOGGER_LOG_LEVEL=info
MIDDLEWARE_GLOBAL_LOGGER_INCLUDE_CONTENT=false
MIDDLEWARE_GLOBAL_LOGGER_SENSITIVE_FIELDS=token,password
MIDDLEWARE_GLOBAL_METRICS_ENABLED=false
MIDDLEWARE_GLOBAL_METRICS_TRACK_COUNTS=true
MIDDLEWARE_GLOBAL_METRICS_TRACK_PERFORMANCE=false
