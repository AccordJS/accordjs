{
    "name": "accordjs",
    "version": "1.0.0",
    "description": "A modern TypeScript project built with Bun",
    "module": "src/index.ts",
    "type": "module",
    "private": true,
    "keywords": [
        "bun",
        "typescript",
        "template"
    ],
    "author": "Angel Moreno <angel@angelxmoreno.com>",
    "repository": {
        "type": "git",
        "url": "https://github.com/AccordJS/accordjs.git"
    },
    "bugs": {
        "url": "https://github.com/AccordJS/accordjs/issues"
    },
    "homepage": "https://github.com/AccordJS/accordjs#readme",
    "scripts": {
        "prepare": "bun lefthook install",
        "dev": "bun --hot src/index.ts",
        "build": "tsc",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "check-types": "tsc --noEmit",
        "check-dups": "bun run check-jsinspect && bun run check-jscpd",
        "check-jsinspect": "jsinspect -t 50 --ignore \"node_modules|dist|supabase|docs|tests\" ./src",
        "check-jscpd": "jscpd --config=./jscpd.json ./src",
        "test": "bun test",
        "test:coverage": "bun test --coverage --coverage-reporter=lcov",
        "check": "bun run check-types && bun run lint && bun run check-dups"
    },
    "dependencies": {
        "discord.js": "14.25.1",
        "dotenv": "^17.3.1",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.7",
        "@commitlint/cli": "^20.4.4",
        "@commitlint/config-conventional": "^20.4.4",
        "@types/bun": "^1.3.10",
        "@types/node": "^25.5.0",
        "jscpd": "^4.0.8",
        "jsinspect-plus": "^3.1.3",
        "lefthook": "^2.1.4",
        "typescript": "^5.9.3"
    }
}
